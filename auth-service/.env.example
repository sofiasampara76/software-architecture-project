# Auth Service environment variables
# Copy to .env (locally) or inject via docker-compose `environment:` block.

# JWT signing — MUST be a strong random string in any real deployment.
# Generate one with:  python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET_KEY=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Postgres connection string
DATABASE_URL=postgresql://user:password@auth-db:5432/auth_db
