# Root .env.example — copy to .env if you want to override defaults.
# The docker-compose.yml already wires sensible defaults; you usually
# don't need to override anything for local demos.

GATEWAY_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# Inject chaos in payment service: 0.0 = always succeed, 0.5 = 50% declines
PAYMENT_FAIL_RATE=0.0
